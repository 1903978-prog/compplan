# ============================================================================
# BACKUP SYSTEM CONFIGURATION
# Copy this file to .env.backup and fill in real values
# NEVER commit .env.backup to Git
# ============================================================================

# ── Neon Database (use NON-POOLED connection string) ────────────────────────
# Get this from Neon Console > Connection Details > Direct connection
# Must be the non-pooled URL (not the one ending in -pooler.neon.tech)
DATABASE_URL_BACKUP_SOURCE="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ── Restore target (use a DIFFERENT database for testing restores) ──────────
# Create a separate Neon branch or use a local Postgres for restore testing
DATABASE_URL_RESTORE_TARGET="postgresql://user:password@localhost:5432/compplan_restore_test"

# ── AWS S3 Configuration ───────────────────────────────────────────────────
# Create a dedicated IAM user with ONLY s3:PutObject, s3:GetObject, s3:ListBucket
# on the specific backup bucket. Never use root credentials.
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="AKIA_YOUR_KEY_HERE"
AWS_SECRET_ACCESS_KEY="your_secret_key_here"
BACKUP_S3_BUCKET="your-compplan-backups"
BACKUP_S3_PREFIX="compplan"

# ── Git Mirror (optional — for code backup to a second remote) ─────────────
# Create a private repo on GitLab/another GitHub org and paste the URL
# Use SSH URL for key-based auth or HTTPS with token embedded
SECONDARY_GIT_REMOTE_URL=""

# ── Notification (optional) ────────────────────────────────────────────────
# Webhook URL for backup success/failure notifications (Slack, Discord, etc.)
BACKUP_WEBHOOK_URL=""
