# Example environment variables.
# Copy to .env and fill in real values — .env is gitignored.

# App-wide password gate. When set, every user must enter this password
# on the login screen (served by /api/auth/login). Leave empty or remove
# to disable the gate (dev convenience only — never ship without it).
APP_PASSWORD=change-me

# Bearer token gating GET /api/ceo-brief (the public, machine-readable
# version of the daily CEO Brief that external tools — Cowork skills,
# schedulers, etc. — can fetch). Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then set it on Render → Environment as CEO_BRIEF_TOKEN.
# When unset, /api/ceo-brief returns 503 (never accidentally open).
CEO_BRIEF_TOKEN=

# Local path where DB dumps and code zips are written when using the
# "Save to disk" buttons in Admin → Backup & Restore.
# Must be an absolute path. Leave empty to disable (falls back to browser download).
# LOCAL_BACKUP_DIR=C:\Users\yourname\OneDrive\backups\compplan

# Optional integrations
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...          (or GOOGLE_API_KEY — either is read)
# OPENAI_API_KEY=sk-...
# HARVEST_TOKEN=
# HARVEST_ACCOUNT_ID=
# EENDIGO_USERNAME=
# EENDIGO_PASSWORD=
# READ_AI_TOKEN=                  (optional; falls back to seeded snapshot)
# HUBSPOT_TOKEN=                  (Private App token — HubSpot → Settings → Integrations → Private Apps)
